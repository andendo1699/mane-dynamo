            "logo_width": 120
          }
        },
        "template--19886097793322__9477cb49-16ee-4bcf-a04c-bf55ee8d3bc2-1688737592c993cae0-0": {
          "type": "press",
          "settings": {
            "text": "<p>Their designs blend sleek aesthetics with modern sensibilities, resulting in bags that are both sophisticated and practical.</p>",
            "link": "",
            "logo_width": 120
          }
        },
        "template--19886097793322__9477cb49-16ee-4bcf-a04c-bf55ee8d3bc2-1688737592c993cae0-2": {
          "type": "press",
          "settings": {
            "text": "<p>The use of premium materials and robust construction techniques ensures that their bags can withstand the demands of daily use and provide long-lasting protection for valuable tech gear.</p>",
            "link": "",
            "logo_width": 120
          }
        }
      },
