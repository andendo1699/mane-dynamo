            "card_background": "#ffffff",
            "card_border": "#d6d9e1",
            "text_color": "#212121",
            "star_color": "#ff763d",
            "review_text": "\"Was wearing baseball caps to client meetings. Now my clients look at me, not my forehead. Paid £25 for 1, then instantly regretted not going for 2. You WILL reorder, just be smart and save money the first time.\"",
            "customer_name": "Michael",
