{%- assign has_text = false -%}
{%- for i in (1..4) -%}
  {%- assign icon_text = 'icon_text_' | append: forloop.index -%}
  {%- assign icon_text = block_settings[icon_text] -%}
  {%- assign icon_subtext = 'icon_subtext_' | append: forloop.index -%}
  {%- assign icon_subtext = block_settings[icon_subtext] -%}

  {%- if icon_text != '' or icon_subtext != '' -%}
    {%- assign has_text = true -%}
  {%- endif -%}
{%- endfor -%}

{%- for i in (1..4) -%}
  {%- assign icon_name = 'icon_name_' | append: forloop.index -%}
  {%- assign icon_name = block_settings[icon_name] -%}
  {%- assign icon_color = 'icon_color_' | append: forloop.index -%}
  {%- assign icon_color = block_settings[icon_color] -%}
  {%- assign icon_image = 'icon_image_' | append: forloop.index -%}
  {%- assign icon_image = block_settings[icon_image] -%}
  {%- assign icon_width = 'icon_width_' | append: forloop.index -%}
  {%- assign icon_width = block_settings[icon_width] -%}
  {%- assign icon_text = 'icon_text_' | append: forloop.index -%}
  {%- assign icon_text = block_settings[icon_text] -%}
  {%- assign icon_subtext = 'icon_subtext_' | append: forloop.index -%}
  {%- assign icon_subtext = block_settings[icon_subtext] -%}

  {%- if icon_image != blank -%}
    {%- assign retina_size = icon_width | times: 2 -%}
    {%- assign image_widths = icon_width | append: ', ' | append: retina_size -%}
    {%- assign sizes = icon_width | append: 'px' -%}
  {%- endif -%}

  {%- capture icon_style -%}
    --icon-size: {{ icon_width }}px;

    {%- if icon_image == blank and icon_name == 'none' and icon_text != '' and icon_subtext == '' -%}
      --offset-top: 0;
    {%- endif -%}

    {%- if icon_image -%}
      --aspect-ratio: {{ 1 | divided_by: icon_image.aspect_ratio | times: 100 | round: 1 }}%;
    {%- endif -%}

    {%- if icon_color != '' and icon_color != 'rgba(0,0,0,0)' and icon_image == blank -%}
      --icon-color: {{ icon_color }};
    {%- endif -%}
  {%- endcapture -%}

  {%- unless icon_image == blank and icon_name == 'none' and icon_text == '' and icon_subtext == '' -%}
    <div class="icons-row-block__item{% unless has_text %} icons-row-block__item--center{% endunless %}" style="{{ icon_style }}">
      {%- unless icon_image == blank and icon_name == 'none' -%}
        <div class="icons-row-block__icon icon-stroke">
          {%- if icon_image != blank -%}
            <div class="icons-row-block__holder">
              {%- render 'image',
                image: icon_image,
                width: retina_size,
                widths: image_widths,
                sizes: sizes,
                classes: 'icons-row-block__img' -%}
            </div>
          {%- elsif icon_name == 'asset-truck' -%}
            <div class="icons-row-block__holder">
              <img
                src="{{ 'product-icon-truck.webp' | asset_url }}"
                width="{{ icon_width }}"
                height="{{ icon_width }}"
                loading="lazy"
                class="icons-row-block__img"
                alt=""
              >
            </div>
          {%- elsif icon_name == 'asset-verified' -%}
            <div class="icons-row-block__holder">
              <img
                src="{{ 'product-icon-verified.png' | asset_url }}"
                width="{{ icon_width }}"
                height="{{ icon_width }}"
                loading="lazy"
                class="icons-row-block__img"
                alt=""
              >
            </div>
          {%- else -%}
            {%- render 'icons', icon: icon_name -%}
          {%- endif -%}
        </div>
      {%- endunless -%}
      <div class="icons-row-block__textwrap">
        {%- if icon_text != blank -%}
          <span class="icons-row-block__text icons-row-block__text--meta">{{ icon_text }}</span>
        {%- endif -%}
        {%- if icon_subtext != blank -%}
          <span class="icons-row-block__text icons-row-block__text--title">{{ icon_subtext }}</span>
        {%- endif -%}
      </div>
    </div>
  {%- endunless -%}
{%- endfor -%}