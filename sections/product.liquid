{%- comment -%} /sections/product-template {%- endcomment -%}
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign selected_color_scheme = section.settings.color_scheme | strip
  assign scheme_bg_color = settings.color_schemes[selected_color_scheme].settings.section_bg
  assign section_width = section.settings.width
  assign section_id = 'productTemplate--' | append: section.id
  assign selector_id = '#' | append: section_id
  assign animation_anchor = selector_id
  assign animations_enabled = settings.animations_enabled

  assign scheme_bg_color_brightness = scheme_bg_color | color_brightness | round
  if scheme_bg_color_brightness < 153
    assign color_scheme = color_scheme | append: ' palette--dark'
  else
    assign color_scheme = color_scheme | append: ' palette--light'
  endif
-%}

{%- style -%}
  {{ selector_id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="{{ section_id }}"
  class="section-padding product-single {{ color_scheme }}{%- render 'button-fallback-classes', primary_color: settings.atc_button_color, secondary_color: settings.buynow_btn_color -%}"
  data-enable-history-state="true"
  data-section-type="product-template"
  data-section-id="{{ section.id }}"
  {% if animations_enabled %}
    data-aos-intersection="0.01"
  {% endif %}
  {% if product.tags contains '_preorder' %}
    data-preorder-type-product
  {% endif %}
>
  <div class="{{ section_width }}">
    {%- render 'product', animation_anchor: animation_anchor -%}
  </div>
</section>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

